<Window x:Class="Checkers.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Checkers"
        xmlns:views="clr-namespace:Checkers.Views"
        mc:Ignorable="d"
        Title="Шашки" Height="650" Width="600"
        Icon="app.ico"
        Background="#2c3e50">

    <Grid>
        <!-- Лобби (показывается по умолчанию) -->
        <views:LobbyView x:Name="LobbyView" Visibility="Visible" DataContext="{Binding LobbyViewModel}"/>

        <!-- Игра (скрыта по умолчанию) -->
        <views:GameView x:Name="GameView" Visibility="Collapsed" DataContext="{Binding}"/>
    </Grid>
</Window>