<UserControl x:Class="Checkers.Views.LobbyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Checkers.Views"
             xmlns:checkers="clr-namespace:Checkers"
             mc:Ignorable="d"
             d:DesignHeight="650" d:DesignWidth="600">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid Margin="40">
        <!-- Version + Update (bottom of lobby) -->
        <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,0">
            <TextBlock Text="{Binding VersionText}"
                       Foreground="#7f8c8d"
                       FontSize="12"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="{Binding UpdateStatus}"
                       Foreground="#f1c40f"
                       FontSize="12"
                       HorizontalAlignment="Center"
                       Margin="0,4,0,0"/>
            <Button Content="Обновить"
                    Command="{Binding UpdateCommand}"
                    Visibility="{Binding IsUpdateAvailable, Converter={StaticResource BoolToVis}}"
                    Height="30"
                    Width="120"
                    FontSize="12"
                    Background="#3498db"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    Margin="0,6,0,0">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="4"
                                            Padding="6">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>

        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <!-- Заголовок -->
            <TextBlock Text="ШАШКИ"
                       FontSize="48"
                       FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,40"/>

            <!-- Режим игры -->
            <TextBlock Text="Режим игры:"
                       Foreground="White"
                       FontSize="18"
                       Margin="0,0,0,10"/>
            <ComboBox Name="GameModeComboBox"
                      SelectedValue="{Binding SelectedGameMode}"
                      SelectedValuePath="Tag"
                      Height="35"
                      Width="250"
                      FontSize="14"
                      Margin="0,0,0,20">
                <ComboBoxItem Content="Игрок против Игрока" Tag="PvP"/>
                <ComboBoxItem Content="Игрок против Бота" Tag="PvB"/>
                <ComboBoxItem Content="Онлайн (LAN)" Tag="Online"/>
            </ComboBox>

            <!-- Оффлайн: выбор цвета + кнопка старта -->
            <StackPanel Visibility="{Binding IsOfflineMode, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="Ваши шашки:"
                           Foreground="White"
                           FontSize="18"
                           Margin="0,0,0,10"/>
                <ComboBox Name="PlayerColorComboBox"
                          SelectedValue="{Binding SelectedPlayerColor}"
                          SelectedValuePath="Tag"
                          Height="35"
                          Width="250"
                          FontSize="14"
                          Margin="0,0,0,30">
                    <ComboBoxItem Content="Белые" Tag="White"/>
                    <ComboBoxItem Content="Черные" Tag="Black"
                                  IsEnabled="{Binding IsBlackColorEnabled}"/>
                </ComboBox>

                <Button Content="НАЧАТЬ ИГРУ"
                        Command="{Binding StartGameCommand}"
                        Height="60"
                        Width="250"
                        FontSize="18"
                        FontWeight="Bold"
                        Background="#2ecc71"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="8"
                                                Padding="15"
                                                BorderThickness="2"
                                                BorderBrush="#27ae60">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>

            <!-- Онлайн: хост / подключение -->
            <StackPanel Visibility="{Binding IsOnlineMode, Converter={StaticResource BoolToVis}}">

                <!-- Кнопка "Создать игру" (хост) -->
                <Button Content="СОЗДАТЬ ИГРУ (Хост)"
                        Command="{Binding HostGameCommand}"
                        Height="50"
                        Width="250"
                        FontSize="16"
                        FontWeight="Bold"
                        Background="#3498db"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Margin="0,0,0,15">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="8"
                                                Padding="10"
                                                BorderThickness="2"
                                                BorderBrush="#2980b9">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Разделитель -->
                <TextBlock Text="— или —"
                           Foreground="#7f8c8d"
                           FontSize="14"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,15"/>

                <!-- Ввод IP + кнопка подключения -->
                <TextBlock Text="IP хоста:"
                           Foreground="White"
                           FontSize="16"
                           Margin="0,0,0,5"/>
                <TextBox Text="{Binding RemoteIp, UpdateSourceTrigger=PropertyChanged}"
                         Height="35"
                         Width="250"
                         FontSize="14"
                         Margin="0,0,0,10"/>

                <Button Content="ПОДКЛЮЧИТЬСЯ"
                        Command="{Binding JoinGameCommand}"
                        Height="50"
                        Width="250"
                        FontSize="16"
                        FontWeight="Bold"
                        Background="#e67e22"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Margin="0,0,0,15">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="8"
                                                Padding="10"
                                                BorderThickness="2"
                                                BorderBrush="#d35400">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Статус соединения -->
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{Binding ConnectionStatus}"
                               Foreground="#f1c40f"
                               FontSize="14"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap"/>
                    <Button Content="Копировать IP"
                            Command="{Binding CopyIpCommand}"
                            Visibility="{Binding HasIpToCopy, Converter={StaticResource BoolToVis}}"
                            Height="28"
                            Width="120"
                            FontSize="11"
                            Background="#7f8c8d"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Margin="0,6,0,0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="4"
                                                    Padding="4">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
