<UserControl x:Class="Checkers.Views.GameView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Checkers.Views"
             xmlns:vm="clr-namespace:Checkers.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="650" d:DesignWidth="600">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- Иконка короны для дамки -->
        <DrawingImage x:Key="CrownIcon">
            <DrawingImage.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="Gold">
                        <GeometryDrawing.Pen>
                            <Pen Brush="#b8860b" Thickness="1" />
                        </GeometryDrawing.Pen>
                        <GeometryDrawing.Geometry>
                            <PathGeometry Figures="M2 4 L3 12 L21 12 L22 4 L16 11 L12 4 L8 11 L2 4 Z M3 16 L21 16 L21 18 L3 18 Z" />
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingImage.Drawing>
        </DrawingImage>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- Статус-бар сверху -->
            <RowDefinition Height="*" />    <!-- Игровое поле -->
        </Grid.RowDefinitions>

        <!-- Текст сверху: чей сейчас ход -->
        <TextBlock Text="{Binding StatusMessage}"
                   FontSize="24" FontWeight="Bold" Foreground="White"
                   HorizontalAlignment="Center" Margin="0,0,0,20" />

        <!-- Сама доска -->
        <ItemsControl Grid.Row="1" ItemsSource="{Binding Cells}">
            <!-- Говорим, что элементы должны лежать в сетке 8x8 -->
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Rows="8" Columns="8" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <!-- Описываем, как выглядит одна клетка (наша кнопка) -->
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:CellViewModel}">
                    <Button Command="{Binding DataContext.HandleCellClickCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"
                            BorderThickness="0">
                        <!-- Стиль кнопки (цвет клетки) -->
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#ecf0f1" /> <!-- Светлая клетка -->
                                <Style.Triggers>
                                    <!-- Если (Row + Col) нечетное — клетка темная -->
                                    <DataTrigger Binding="{Binding IsDark}" Value="True">
                                        <Setter Property="Background" Value="#95a5a6" />
                                    </DataTrigger>
                                    <!-- Если клетка выбрана — подсвечиваем синим -->
                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                        <Setter Property="Background" Value="#3498db" />
                                    </DataTrigger>
                                    <!-- Если клетка доступна для хода — подсвечиваем зеленым -->
                                    <DataTrigger Binding="{Binding IsTarget}" Value="True">
                                        <Setter Property="Background" Value="#2ecc71" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>

                        <!-- Рисуем шашку внутри кнопки (если она есть) -->
                        <Grid>
                            <Ellipse Width="40" Height="40" Stroke="Black" StrokeThickness="1">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <!-- Показываем, если Checker не null -->
                                            <DataTrigger Binding="{Binding HasChecker}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                            <!-- Цвет шашки -->
                                            <DataTrigger Binding="{Binding CheckerColorName}" Value="White">
                                                <Setter Property="Fill" Value="White" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding CheckerColorName}" Value="Black">
                                                <Setter Property="Fill" Value="#2c3e50" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <!-- Корона для дамки -->
                            <Image Width="20" Height="20"
                                   Source="{StaticResource CrownIcon}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsKing}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                        </Grid>
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</UserControl>